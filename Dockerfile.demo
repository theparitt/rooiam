FROM node:22-alpine AS build

WORKDIR /app

ARG VITE_API_URL
ARG VITE_LOGIN_WIDGET_URL

ENV VITE_API_URL=$VITE_API_URL
ENV VITE_LOGIN_WIDGET_URL=$VITE_LOGIN_WIDGET_URL

COPY candycloud-web/package*.json ./
RUN npm install
COPY candycloud-web/ ./
RUN npm run build

FROM nginx:1.27-alpine

COPY nginx-spa.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 80
