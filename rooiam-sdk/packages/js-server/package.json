{
  "name": "@rooiam/sdk-server",
  "version": "0.1.0",
  "description": "Server-side TypeScript SDK for the Rooiam workspace integration API (API-key auth).",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "gen": "openapi-typescript ../../spec/openapi.json -o src/generated/schema.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
