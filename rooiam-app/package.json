{
    "name": "rooiam-app",
    "private": true,
    "version": "0.1.0",
    "license": "Apache-2.0",
    "type": "module",
    "scripts": {
        "dev": "vite --mode prod-local",
        "dev:prod-local": "vite --mode prod-local --port 5172 --strictPort",
        "dev:demo-local": "vite --mode demo-local --port 5182 --strictPort",
        "build": "tsc && vite build --mode prod-online",
        "build:prod-online": "tsc && vite build --mode prod-online",
        "build:demo-online": "tsc && vite build --mode demo-online",
        "start": "vite preview",
        "deploy": "npm run build:prod-online && wrangler pages deploy dist --project-name rooiam-app --branch main --commit-dirty=true",
        "deploy:demo": "npm run build:demo-online && wrangler pages deploy dist --project-name rooiam-app --branch main --commit-dirty=true",
        "pages:dev": "wrangler pages dev dist",
        "pages:deploy": "wrangler pages deploy dist --project-name rooiam-app --branch main --commit-dirty=true"
    },
    "dependencies": {
        "@rooiam/sdk-browser": "file:../rooiam-sdk/packages/js-browser",
        "@types/qrcode": "^1.5.6",
        "clsx": "^2.1.0",
        "lucide-react": "^0.320.0",
        "qrcode": "^1.5.4",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-router-dom": "^6.22.0"
    },
    "devDependencies": {
        "@types/react": "^18.2.43",
        "@types/react-dom": "^18.2.17",
        "@vitejs/plugin-react": "^4.2.1",
        "autoprefixer": "^10.4.17",
        "postcss": "^8.4.33",
        "tailwindcss": "^3.4.1",
        "typescript": "^5.2.2",
        "vite": "^5.0.8",
        "wrangler": "^4.78.0"
    }
}
