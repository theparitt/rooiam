# ── Server ────────────────────────────────────────────────────────────────────
CANDYCLOUD_PORT=5185

# ── Rooiam API ────────────────────────────────────────────────────────────────
# The Rooiam demo server — backend calls this directly (no browser CORS)
ROOIAM_API_URL=http://localhost:5180/v1

# ── Redis ─────────────────────────────────────────────────────────────────────
CANDYCLOUD_REDIS_URL=redis://localhost:6379

# ── Cookie ────────────────────────────────────────────────────────────────────
# Set to true in production (requires HTTPS)
CANDYCLOUD_COOKIE_SECURE=false
# Scope cookie to *.rooiam.com so candycloud.rooiam.com and candycloud-api.rooiam.com share it
# Leave empty for local dev
CANDYCLOUD_COOKIE_DOMAIN=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CANDYCLOUD_ALLOWED_ORIGINS=http://localhost:5184
