# Source-run env: demo behavior + public deployment

ROOIAM_MODE=demo
ROOIAM_DEPLOY_TARGET=public

ROOIAM_HOST=0.0.0.0
ROOIAM_PORT=5180

ROOIAM_SERVER_URL=https://demo-api.rooiam.com
ROOIAM_ADMIN_URL=https://demo-admin.rooiam.com
ROOIAM_APP_URL=https://demo-app.rooiam.com
ROOIAM_ENDUSER_URL=https://candycloud.rooiam.com
ROOIAM_DOCS_URL=https://docs.rooiam.com

ROOIAM_ALLOWED_ORIGINS=https://candycloud.rooiam.com,https://demo-admin.rooiam.com,https://demo-app.rooiam.com

ROOIAM_COOKIE_SECURE=true
ROOIAM_COOKIE_DOMAIN=rooiam.com

ROOIAM_DATABASE_URL=postgres://rooiam:your_secure_demo_password_here@postgres:5432/rooiam_demo
ROOIAM_REDIS_URL=redis://redis:6379

ROOIAM_PUBLIC_MEDIA_BASE=https://demo-api.rooiam.com/media
ROOIAM_MINIO_ENDPOINT=http://minio:9000
ROOIAM_MINIO_BUCKET=rooiam_demo
ROOIAM_MINIO_USER=rooiam
ROOIAM_MINIO_PASSWORD=your_secure_demo_minio_password_here

ROOIAM_DEMO_SMTP_HOST=mailhog
ROOIAM_DEMO_SMTP_PORT=1025
ROOIAM_DEMO_SMTP_FROM=demo@rooiam.com
ROOIAM_DEMO_MAILBOX_URL=https://demo-mail.rooiam.com
